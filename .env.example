# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit it.
#
# All variables are optional; the YAML profiles provide sensible defaults.
# Environment variables have higher priority than YAML but lower than CLI flags.

# Appium server URL (omit trailing slash)
# APPIUM_SERVER_URL=http://127.0.0.1:4723

# ADB device UDID. Leave blank to auto-detect via `adb devices`
# DEVICE_UDID=

# App package / activity — only needed if targeting a different build
# APP_PACKAGE=co.hinge.app
# APP_ACTIVITY=co.hinge.app.MainActivity

# UI locale for selector resolution.
# Registered locales: pt-PT, en-US
# Add more in src/hinge_bot/selectors.py (see the module docstring).
# HINGE_LOCALE=pt-PT
